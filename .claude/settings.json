{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Read",
      "Glob",
      "Grep",
      "Write"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__node_repl__js",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/block-playwright.sh\"",
            "timeout": 10,
            "statusMessage": "Checking for Playwright (use agent-browser)…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(gh pr create *)",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f pr.md"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/verify-browser-reminder.sh\"",
            "timeout": 15,
            "statusMessage": "Checking UI changes were browser-verified…"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "honcho@honcho": true
  },
  "extraKnownMarketplaces": {
    "honcho": {
      "source": {
        "source": "github",
        "repo": "plastic-labs/claude-honcho"
      }
    }
  },
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": true,
  "switchModelsOnFlag": false,
  "terminalProgressBarEnabled": false,
  "skipAutoPermissionPrompt": true
}
