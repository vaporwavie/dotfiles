#!/usr/bin/env bash
set -u

claude_bin="${CLAUDE_P_BIN:-/Users/router/.local/bin/claude}"
interval="${CLAUDE_P_HEARTBEAT_SECONDS:-10}"
stream="${CLAUDE_P_HEARTBEAT_STREAM:-stderr}"

if [[ ! -x "$claude_bin" ]]; then
  echo "claude-p-watch: Claude binary is not executable: $claude_bin" >&2
  exit 127
fi

case "$interval" in
  ''|*[!0-9]*)
    echo "claude-p-watch: CLAUDE_P_HEARTBEAT_SECONDS must be a positive integer" >&2
    exit 2
    ;;
esac

if (( interval < 1 )); then
  echo "claude-p-watch: CLAUDE_P_HEARTBEAT_SECONDS must be at least 1" >&2
  exit 2
fi

heartbeat() {
  local message="$1"
  if [[ "$stream" == "stdout" ]]; then
    printf '%s\n' "$message"
  else
    printf '%s\n' "$message" >&2
  fi
}

"$claude_bin" "$@" &
child_pid=$!

forward_signal() {
  local signal="$1"
  kill "-$signal" "$child_pid" 2>/dev/null || true
}

trap 'forward_signal TERM' TERM
trap 'forward_signal INT' INT
trap 'forward_signal HUP' HUP

start_time="$(date +%s)"
(
  while kill -0 "$child_pid" 2>/dev/null; do
    sleep "$interval" || exit 0
    kill -0 "$child_pid" 2>/dev/null || exit 0
    now="$(date +%s)"
    elapsed="$((now - start_time))"
    heartbeat "[claude-p-watch] waiting for Claude output (${elapsed}s elapsed)"
  done
) &
heartbeat_pid=$!

wait "$child_pid"
status=$?

kill "$heartbeat_pid" 2>/dev/null || true
wait "$heartbeat_pid" 2>/dev/null || true

exit "$status"
