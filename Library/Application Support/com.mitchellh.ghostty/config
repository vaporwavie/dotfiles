theme = light:grokday,dark:groknight
macos-titlebar-style = "tabs"
window-padding-x = 10
#window-padding-y = 10
font-family = "0xProto"
font-size = 16
adjust-cell-height = 35%
cursor-style-blink = false
shell-integration-features = no-cursor
mouse-hide-while-typing = true
confirm-close-surface = false
window-save-state = always
shell-integration = zsh
keybind = global:cmd+page_down=toggle_quick_terminal
window-vsync = false
unfocused-split-opacity = 0.5
keybind = shift+enter=text:\x1b\r

# Dump screen / full scrollback to a temp file; Ghostty pastes the path + newline,
# and a zsh accept-line wrapper (_vh_accept_line in .zshrc) opens it in `vh`.
keybind = cmd+shift+e=write_screen_file:paste
keybind = cmd+shift+b=write_scrollback_file:paste
